APP_NAME=travel-planner-assistant
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=86400
PROFILE_TTL_SECONDS=2592000
SESSION_HISTORY_LIMIT=12
MEMORY_ENABLED=true
HTTP_TIMEOUT_SECONDS=8

WECOM_TOKEN=replace-with-wecom-token
WECOM_AGENT_ID=1000002
WECOM_CORP_ID=replace-with-wecom-corp-id
WECOM_ENCODING_AES_KEY=replace-with-wecom-encoding-aes-key
WECOM_CONNECTION_MODE=webhook
WECOM_BOT_ID=replace-with-wecom-bot-id
WECOM_BOT_SECRET=replace-with-wecom-bot-secret
WECOM_WS_URL=wss://openws.work.weixin.qq.com
WECOM_WS_HEARTBEAT_INTERVAL_SECONDS=30
WECOM_WS_MAX_MISSED_HEARTBEAT=2
WECOM_WS_RECONNECT_BASE_DELAY_SECONDS=1
WECOM_WS_RECONNECT_MAX_DELAY_SECONDS=30
WECOM_WS_MAX_AUTH_FAILURE_ATTEMPTS=5

QQ_ENABLED=false
QQ_BOT_APP_ID=replace-with-qq-bot-app-id
QQ_BOT_CLIENT_SECRET=replace-with-qq-bot-client-secret
QQ_API_BASE_URL=https://api.sgroup.qq.com
QQ_AUTH_BASE_URL=https://bots.qq.com
QQ_WS_INTENTS=1107296256
QQ_WS_MAX_MISSED_HEARTBEAT=2
QQ_WS_RECONNECT_BASE_DELAY_SECONDS=1
QQ_WS_RECONNECT_MAX_DELAY_SECONDS=30
QQ_WS_MAX_AUTH_FAILURE_ATTEMPTS=5
QQ_EVENT_DEDUP_TTL_SECONDS=120
QQ_EVENT_DEDUP_MAX_SIZE=5000

QWEATHER_API_KEY=replace-with-qweather-api-key
QWEATHER_API_HOST=https://replace-with-your-qweather-api-host
AMAP_API_KEY=replace-with-amap-api-key
AMAP_DEFAULT_CITY=上海
SERPAPI_API_KEY=replace-with-serpapi-api-key

LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace-with-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=8
LLM_TEMPERATURE=0.2
